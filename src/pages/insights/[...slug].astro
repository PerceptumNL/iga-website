---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const insights = await getCollection('insights');
  return insights.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const tocHeadings = headings.filter(h => h.depth === 2);
---

<Layout title={`${entry.data.title} | IGA Insights`} description={entry.data.description}>

  <article class="pt-32 pb-24 lg:pt-40 lg:pb-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav class="fade-up mb-10" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-gray-400">
          <li><a href={`${base}`} class="hover:text-iga-black transition-colors">Home</a></li>
          <li><span class="mx-1">/</span></li>
          <li><a href={`${base}insights`} class="hover:text-iga-black transition-colors">Insights</a></li>
          <li><span class="mx-1">/</span></li>
          <li class="text-iga-black font-medium truncate max-w-[300px]">{entry.data.title}</li>
        </ol>
      </nav>

      <!-- Article Header -->
      <header class="fade-up max-w-3xl mb-12">
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-block bg-iga-blue/15 text-iga-blue-dark text-xs font-semibold tracking-wider uppercase px-3 py-1">{entry.data.category}</span>
          <span class="text-xs text-gray-400">{entry.data.readTime}</span>
          <span class="text-xs text-gray-400">·</span>
          <time class="text-xs text-gray-400">{new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        </div>

        <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight leading-[1.15] mb-6">{entry.data.title}</h1>

        <p class="text-lg md:text-xl text-gray-500 leading-relaxed">{entry.data.description}</p>
      </header>

      <div class="gradient-line mb-12"></div>

      <!-- Layout: TOC sidebar + Content -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-16">

        <!-- Article Content -->
        <div class="fade-up min-w-0">
          <div class="prose prose-lg max-w-none
            prose-headings:font-serif prose-headings:tracking-tight prose-headings:text-iga-black
            prose-h2:text-[1.65rem] prose-h2:leading-tight prose-h2:mt-14 prose-h2:mb-5 prose-h2:pb-3 prose-h2:border-b prose-h2:border-gray-100
            prose-h3:text-xl prose-h3:mt-10 prose-h3:mb-4
            prose-p:text-gray-600 prose-p:leading-[1.8] prose-p:mb-5
            prose-strong:text-iga-black prose-strong:font-semibold
            prose-a:text-iga-blue prose-a:font-medium prose-a:no-underline hover:prose-a:underline
            prose-ul:my-6 prose-ul:space-y-2
            prose-ol:my-6 prose-ol:space-y-2
            prose-li:text-gray-600 prose-li:leading-relaxed prose-li:pl-1
            prose-table:my-8 prose-table:text-sm prose-table:border prose-table:border-gray-200
            prose-thead:bg-iga-grey/40
            prose-th:px-5 prose-th:py-3 prose-th:text-left prose-th:font-semibold prose-th:text-iga-black prose-th:text-xs prose-th:uppercase prose-th:tracking-wider
            prose-td:px-5 prose-td:py-3 prose-td:border-t prose-td:border-gray-100 prose-td:text-gray-600
            prose-em:text-iga-black prose-em:font-medium prose-em:not-italic
            prose-blockquote:border-l-[3px] prose-blockquote:border-iga-blue prose-blockquote:bg-iga-grey/15 prose-blockquote:pl-6 prose-blockquote:pr-6 prose-blockquote:py-4 prose-blockquote:my-8 prose-blockquote:not-italic prose-blockquote:text-gray-600 prose-blockquote:rounded-r
            prose-hr:border-gray-200 prose-hr:my-12
            prose-img:rounded
          ">
            <Content />
          </div>
        </div>

        <!-- Sidebar: TOC -->
        {tocHeadings.length > 2 && (
          <aside class="hidden lg:block">
            <div class="sticky top-28">
              <p class="text-xs font-semibold tracking-wider uppercase text-gray-400 mb-4">In this article</p>
              <nav class="space-y-2.5">
                {tocHeadings.map((heading) => (
                  <a href={`#${heading.slug}`} class="block text-sm text-gray-500 hover:text-iga-black transition-colors leading-snug">
                    {heading.text}
                  </a>
                ))}
              </nav>

              <div class="mt-10 pt-6 border-t border-gray-100">
                <a href={`${base}contact`} class="block text-sm font-semibold text-iga-black hover:text-iga-blue transition-colors">
                  Schedule a Strategy Session →
                </a>
              </div>
            </div>
          </aside>
        )}
      </div>

      <!-- Author / CTA -->
      <div class="max-w-3xl mt-16 pt-8 border-t border-gray-200">
        <div class="bg-iga-black text-white p-8 lg:p-10">
          <p class="text-sm text-iga-blue font-medium uppercase tracking-wider mb-3">Next step</p>
          <h3 class="font-serif text-2xl font-medium mb-4">Ready to build your revenue system?</h3>
          <p class="text-gray-300 leading-relaxed mb-6">Book a strategy session and we'll analyze your current revenue process, identify where you're leaking growth, and map out a structured system for your business.</p>
          <a href={`${base}contact`} class="inline-flex items-center gap-2 bg-iga-blue text-iga-black px-6 py-3.5 text-sm font-semibold hover:bg-iga-blue-light transition-colors">
            Schedule a Strategy Session
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </a>
        </div>
      </div>
    </div>
  </article>

</Layout>
