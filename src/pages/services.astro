---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
---

<Layout title="Growth Systems | IGA — Engineered Marketing Systems" description="Engineered marketing systems for B2B and B2C businesses. Structured acquisition, conversion, and retention systems that deliver measurable revenue.">

  <!-- Hero -->
  <section class="pt-32 pb-16 lg:pt-40 lg:pb-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="fade-up max-w-3xl">
        <p class="text-sm font-medium tracking-widest uppercase text-iga-blue mb-4">Growth Systems</p>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight mb-8">
          Engineered for your business model
        </h1>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed">
          Every system is tailored to how your business sells. B2B requires different infrastructure than B2C — we build for both. No random campaigns. Structured systems that generate predictable, measurable revenue.
        </p>
      </div>
    </div>
  </section>

  <div class="gradient-line"></div>

  <!-- B2B Growth System -->
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        <div class="fade-up">
          <span class="inline-block bg-iga-black text-white text-xs font-semibold tracking-wider uppercase px-3 py-1 mb-6">B2B</span>
          <h2 class="font-serif text-3xl md:text-4xl font-medium tracking-tight mb-4">Enterprise Revenue Engine</h2>
          <p class="text-gray-600 leading-relaxed text-lg mb-8">
            Built for high-ticket B2B companies that require predictable pipeline and sales efficiency. We target decision-makers with precision and build systems that shorten your sales cycle.
          </p>

          <h3 class="font-serif text-xl font-medium mb-4">The problems we solve</h3>
          <ul class="space-y-3 text-gray-600 mb-10">
            <li class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 bg-red-400 rounded-full mt-2.5 flex-shrink-0"></span>
              Long and inefficient sales cycles
            </li>
            <li class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 bg-red-400 rounded-full mt-2.5 flex-shrink-0"></span>
              Poor lead qualification draining sales resources
            </li>
            <li class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 bg-red-400 rounded-full mt-2.5 flex-shrink-0"></span>
              Marketing and sales misalignment
            </li>
            <li class="flex items-start gap-3">
              <span class="w-1.5 h-1.5 bg-red-400 rounded-full mt-2.5 flex-shrink-0"></span>
              Decision-makers not properly targeted
            </li>
          </ul>

          <h3 class="font-serif text-xl font-medium mb-4">Sectors</h3>
          <div class="flex flex-wrap gap-2 mb-8">
            <span class="text-sm bg-iga-grey/50 text-gray-700 px-4 py-1.5">Operational Technology</span>
            <span class="text-sm bg-iga-grey/50 text-gray-700 px-4 py-1.5">Compliance & Risk Software</span>
            <span class="text-sm bg-iga-grey/50 text-gray-700 px-4 py-1.5">Industrial Innovation</span>
            <span class="text-sm bg-iga-grey/50 text-gray-700 px-4 py-1.5">Workforce Productivity</span>
            <span class="text-sm bg-iga-grey/50 text-gray-700 px-4 py-1.5">Construction & Industry 4.0</span>
          </div>
        </div>

        <div class="fade-up fade-up-delay-2">
          <div class="bg-iga-grey/20 border border-gray-100 p-8 lg:p-10 mb-8">
            <h3 class="font-serif text-xl font-medium mb-6">What we implement</h3>
            <ul class="space-y-3 text-gray-600">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Deep ICP and competitor analysis</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Precise lead qualification systems</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Lead magnet creation</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Funnel and messaging creation</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Executive-level positioning & ROI framing</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Multichannel paid ads</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Continuous marketing research & optimization</li>
            </ul>
          </div>

          <div class="bg-iga-black text-white p-8">
            <h3 class="font-serif text-lg font-medium mb-4">Outcomes</h3>
            <ul class="space-y-2 text-gray-300">
              <li class="flex items-start gap-2"><span class="text-iga-blue">→</span> Increased conversions</li>
              <li class="flex items-start gap-2"><span class="text-iga-blue">→</span> Lower ad waste</li>
              <li class="flex items-start gap-2"><span class="text-iga-blue">→</span> Increased high-intent leads</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="gradient-line"></div>

  <!-- B2C Growth Systems -->
  <section class="py-24 lg:py-32 bg-iga-grey/20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="fade-up mb-16">
        <span class="inline-block bg-iga-blue text-iga-black text-xs font-semibold tracking-wider uppercase px-3 py-1 mb-6">B2C</span>
        <h2 class="font-serif text-3xl md:text-4xl font-medium tracking-tight">Consumer Growth Systems</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Growth Engine -->
        <div class="fade-up card-hover bg-white border border-gray-200 p-8 lg:p-10">
          <h3 class="font-serif text-2xl font-medium mb-2">Growth Engine</h3>
          <p class="text-gray-500 text-sm mb-6">Structured acquisition & conversion</p>
          <div class="gradient-line mb-6"></div>
          <p class="text-gray-600 leading-relaxed mb-8">Designed for companies that need a structured system to attract, qualify, and convert customers.</p>
          <ul class="space-y-2.5 text-sm text-gray-600">
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Deep business & competitor research</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Strategic blueprint development</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Clear messaging translation</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Funnel & qualification architecture</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Landing page creation & optimization</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Paid ads management</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Ongoing market research cycles</li>
            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Monthly strategic review</li>
          </ul>
        </div>

        <!-- Market Dominator -->
        <div class="fade-up fade-up-delay-1 card-hover bg-iga-black text-white border border-gray-800 p-8 lg:p-10 relative overflow-hidden">
          <div class="absolute -top-20 -right-20 w-40 h-40 bg-iga-blue/20 rounded-full blur-3xl"></div>
          <div class="relative">
            <h3 class="font-serif text-2xl font-medium mb-2">Market Dominator</h3>
            <p class="text-gray-400 text-sm mb-6">Aggressive scaling & full optimization</p>
            <div class="h-[2px] bg-gradient-to-r from-iga-blue to-transparent mb-6"></div>
            <p class="text-gray-300 leading-relaxed mb-8">Everything in the Growth Engine, amplified for maximum market capture.</p>
            <p class="text-sm text-iga-blue font-medium mb-4">Everything in Growth Engine, plus:</p>
            <ul class="space-y-2.5 text-sm text-gray-300">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Advanced qualification systems</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Enhanced page structure & messaging for conversions</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Multichannel scaling</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Paid ads A/B testing</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Retention frameworks</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-iga-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Bi-weekly strategic leadership calls</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 lg:py-32 bg-iga-black text-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center fade-up">
      <h2 class="font-serif text-3xl md:text-4xl font-medium tracking-tight mb-6">Ready to build your growth system?</h2>
      <p class="text-gray-300 text-lg mb-10">Book a strategy session and we'll map out what a structured revenue system looks like for your business.</p>
      <a href={`${base}contact`} class="inline-flex items-center gap-2 bg-iga-blue text-iga-black px-8 py-4 text-sm font-semibold hover:bg-iga-blue-light transition-colors">
        Schedule a Strategy Session
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </a>
    </div>
  </section>

</Layout>
