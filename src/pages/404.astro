---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
const base = import.meta.env.BASE_URL;
---

<Layout title="Page Not Found | IGA" description="The page you're looking for doesn't exist.">
  <section class="min-h-screen flex items-center justify-center">
    <div class="text-center px-6">
      <p class="font-serif text-8xl text-iga-blue/30 font-medium mb-4">404</p>
      <h1 class="font-serif text-3xl font-medium mb-4">Page not found</h1>
      <p class="text-gray-600 mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a href={`${base}`} class="inline-flex items-center gap-2 bg-iga-black text-white px-8 py-3 text-sm font-semibold hover:bg-gray-800 transition-colors">
        Back to Home
      </a>
    </div>
  </section>
</Layout>
